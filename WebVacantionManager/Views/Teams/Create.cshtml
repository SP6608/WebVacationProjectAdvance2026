@model WebVacantionManager.ViewModels.TeamCreateViewModel

@{
    ViewData["Title"] = "Create Team";
}

<h2>Create Team</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label asp-for="TeamName" class="form-label"></label>
        <input asp-for="TeamName" class="form-control" />
        <span asp-validation-for="TeamName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ProjectId" class="form-label">Project</label>
        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-control">
            <option value="">-- Select Project --</option>
        </select>
        <span asp-validation-for="ProjectId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="TeamLeaderId" class="form-label">Team Leader</label>
        <select asp-for="TeamLeaderId" asp-items="Model.TeamLeaders" class="form-control">
            <option value="">-- Select Team Leader --</option>
        </select>
        <span asp-validation-for="TeamLeaderId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}