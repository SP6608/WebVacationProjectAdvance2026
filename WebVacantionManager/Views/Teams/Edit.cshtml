@model WebVacantionManager.ViewModels.TeamsEditViewModel

@{
    ViewData["Title"] = "Edit Team";
}

<h2>Edit Team</h2>

<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />

    <div class="form-group mb-3">
        <label asp-for="TeamName" class="form-label"></label>
        <input asp-for="TeamName" class="form-control" />
        <span asp-validation-for="TeamName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ProjectId" class="form-label"></label>
        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-control">
            <option value="">-- Select Project --</option>
        </select>
        <span asp-validation-for="ProjectId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="TeamLeaderId" class="form-label"></label>
        <select asp-for="TeamLeaderId" asp-items="Model.TeamLeaders" class="form-control">
            <option value="">-- Select Team Leader --</option>
        </select>
        <span asp-validation-for="TeamLeaderId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}